sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:get-replication-study-outcome a <https://w3id.org/kpxl/grlc/grlc-query>;
    dct:description "This query returns the ourcome relations of a replication study.";
    dct:license <http://www.apache.org/licenses/LICENSE-2.0>;
    rdfs:label "Get replication study outcome";
    <https://w3id.org/kpxl/grlc/endpoint> <https://w3id.org/np/l/nanopub-query-1.1/repo/type/0e83fe9c436ab274c378c5c7e054ac5cb74d542a01b432b54530c9cbd1330ec5>;
    <https://w3id.org/kpxl/grlc/sparql> """prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix dct: <http://purl.org/dc/terms/>
prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>
prefix sl: <https://w3id.org/sciencelive/o/terms/>

select distinct ?relation ?value where {
  graph npa:graph {
    ?np npa:hasValidSignatureForPublicKeyHash ?pubkey .
    filter not exists { ?npx npx:invalidates ?np ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
    ?np np:hasAssertion ?a .
    ?np npx:introduces ?outcome .
  }
  values ?_replicationStudy_multi_iri {}
  graph ?a {
    ?outcome sl:isOutcomeOf ?_replicationStudy_multi_iri .
  }
  values ?relation { <http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/sciencelive/o/terms/hasOutcomeRepository> <http://schema.org/endDate> <https://w3id.org/sciencelive/o/terms/hasValidationStatus> <https://w3id.org/sciencelive/o/terms/hasConclusionDescription> <https://w3id.org/sciencelive/o/terms/hasEvidenceDescription> <https://w3id.org/sciencelive/o/terms/hasConfidenceLevel> <https://w3id.org/sciencelive/o/terms/hasLimitationsDescription> }
  graph ?a {
    ?outcome ?relation ?value .
  }
}""" .
}

